# Copy to .env and adjust. All vars are build-time (Vite VITE_* are inlined).

# Live weather feeds — point these at your own self-hosted, Open-Meteo-compatible
# server (same /v1/forecast and /v1/air-quality paths). Leave blank to use the
# kiosk's own origin (e.g. behind a reverse proxy that exposes the API there).
VITE_WEATHER_API_BASE=
VITE_AIR_API_BASE=

# Strict offline build: when "true", no remote photo CDN is ever used (only
# bundled photos under public/photos/).
VITE_OFFLINE=
