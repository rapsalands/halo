# Copy to .env and adjust. All vars are build-time (Vite VITE_* are inlined).

# Provider API keys (free tiers, commercial-OK). See docs/weather-providers.md.
# OpenWeather is the global fallback (weather + air quality, all countries).
VITE_OPENWEATHER_KEY=
# US air quality (EPA AirNow); US weather (NWS) needs no key.
VITE_AIRNOW_KEY=
# India air quality (CPCB via data.gov.in).
VITE_DATA_GOV_IN_KEY=

# Optional: only if you self-host an Open-Meteo-compatible server and register
# the openMeteo provider instead of OpenWeather (same /v1/... paths).
VITE_WEATHER_API_BASE=
VITE_AIR_API_BASE=

# Strict offline build: when "true", no remote photo CDN is ever used (only
# bundled photos under public/photos/).
VITE_OFFLINE=
